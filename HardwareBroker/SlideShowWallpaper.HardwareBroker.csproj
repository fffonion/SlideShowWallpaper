<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>SlideShowWallpaper.HardwareBroker</RootNamespace>
    <AssemblyName>SlideShowWallpaper.HardwareBroker</AssemblyName>
    <AssemblyTitle>SlideShowWallpaper Hardware Broker</AssemblyTitle>
    <FileDescription>SlideShowWallpaper Hardware Broker</FileDescription>
    <Product>SlideShowWallpaper</Product>
    <ApplicationIcon>..\Assets\AppIcon.ico</ApplicationIcon>
    <Platforms>x64</Platforms>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ServerGarbageCollection>false</ServerGarbageCollection>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="LibreHardwareMonitorLib" Version="0.9.4" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Models\HardwareMonitorConfig.cs" Link="Models\HardwareMonitorConfig.cs" />
    <Compile Include="..\Services\AppLog.cs" Link="Services\AppLog.cs" />
    <Compile Include="..\Services\CurrentProcessPrivilege.cs" Link="Services\CurrentProcessPrivilege.cs" />
    <Compile Include="..\Services\HardwareMonitorBrokerHost.cs" Link="Services\HardwareMonitorBrokerHost.cs" />
    <Compile Include="..\Services\HardwareMonitorBrokerProtocol.cs" Link="Services\HardwareMonitorBrokerProtocol.cs" />
    <Compile Include="..\Services\HardwareMonitorReader.cs" Link="Services\HardwareMonitorReader.cs" />
    <Compile Include="..\Services\WorkingSetTrimmer.cs" Link="Services\WorkingSetTrimmer.cs" />
  </ItemGroup>
</Project>
