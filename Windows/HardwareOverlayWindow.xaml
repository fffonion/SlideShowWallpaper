<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SlideShowWallpaper.Windows.HardwareOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        x:Name="Root"
        Background="#FF010203">
        <Border
            x:Name="HardwareOverlay"
            Background="#99000000"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10,8">
            <Grid x:Name="HardwareOverlayRoot">
                <Image
                    x:Name="HardwareOverlayBackground"
                    Stretch="UniformToFill"
                    Visibility="Collapsed" />
                <Canvas
                    x:Name="HardwareOverlayCanvas"
                    Visibility="Collapsed" />
                <StackPanel
                    x:Name="HardwareOverlayContent"
                    Spacing="5" />
            </Grid>
        </Border>
    </Grid>
</Window>
