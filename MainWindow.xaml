<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SlideShowWallpaper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" x:Uid="AppTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource>
                    <ImageIconSource.ImageSource>
                        <BitmapImage UriSource="ms-appx:///Assets/AppIcon.png" />
                    </ImageIconSource.ImageSource>
                </ImageIconSource>
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Padding="16,16,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CommandBar
                    HorizontalAlignment="Left"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True">
                    <AppBarButton x:Uid="RefreshButton" Click="RefreshScreens_Click" Icon="Refresh" />
                    <AppBarToggleButton x:Name="AutostartButton" x:Uid="AutostartButton" Click="AutostartButton_Click" Icon="Play" />
                    <AppBarToggleButton
                        x:Name="CloseToTrayButton"
                        x:Uid="CloseToTrayButton"
                        AutomationProperties.AutomationId="CloseToTrayButton"
                        Click="CloseToTrayButton_Click">
                        <AppBarToggleButton.Icon>
                            <FontIcon Glyph="&#xE77A;" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>
                </CommandBar>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Uid="ThemeLabel"
                        VerticalAlignment="Center" />
                    <ComboBox
                        x:Name="ThemeComboBox"
                        x:Uid="ThemeComboBox"
                        MinWidth="150"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="ThemeComboBox"
                        SelectionChanged="ThemeComboBox_SelectionChanged" />
                </StackPanel>
            </Grid>

            <Grid
                x:Name="MonitorLayout"
                Grid.Row="1"
                Margin="0,12,0,0"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="MonitorNavigationPanel"
                    AutomationProperties.AutomationId="MonitorNavigationPanel"
                    Padding="0,4,0,4"
                    Spacing="2" />

                <Border
                    Grid.Column="1"
                    Padding="16,12,16,0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <ContentControl x:Name="MonitorContent" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
